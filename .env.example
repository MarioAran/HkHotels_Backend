# Configuración de Base de Datos PostgreSQL
# Opción 1: Usar DATABASE_URL (recomendado para Render)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Opción 2: Variables individuales (para desarrollo local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hk_hotel_db
DB_USER=postgres
DB_PASSWORD=tu_password

# Secret Key para JWT (generar una larga y aleatoria)
SECRET_KEY=tu_secret_key_muy_segura_aqui

# Orígenes permitidos para CORS
CORS_ORIGINS=https://marioaran.github.io

# Entorno (development/production)
FLASK_ENV=development